# Google Gemini API key (required)
# Get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Secret used to sign login session tokens (required).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Keep this secret and never commit it — anyone with it can forge valid sessions.
JWT_SECRET=replace_with_a_long_random_string

# ── Firebase (required for persistence — pick ONE of the two options below) ──
#
# Get a service account from https://console.firebase.google.com → your
# project → Project settings → Service accounts → Generate new private key.
# That download is a JSON file containing project_id, client_email and
# private_key.
#
# Option A (recommended for Vercel): paste the ENTIRE downloaded JSON file as
# a single-line string into FIREBASE_SERVICE_ACCOUNT_KEY.
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Option B (easier to manage in a local .env): split the same three fields
# out individually instead of using FIREBASE_SERVICE_ACCOUNT_KEY above.
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR\nKEY\nHERE\n-----END PRIVATE KEY-----\n"

# Optional: local server port (defaults to 3000). Vercel sets this automatically.
PORT=3000

# Optional: restrict CORS to a specific frontend origin in production
# (defaults to "*" which is fine for local dev / same-origin deployment)
CORS_ORIGIN=*

# Optional: max requests per 15-minute window for the AI-calling routes
# (/api/generate and /api/follow-up). Defaults to 30.
AI_RATE_LIMIT_MAX=30

# Optional: max requests per 15-minute window for auth routes
# (/api/auth/signup and /api/auth/login), to slow down brute-force attempts.
# Defaults to 20.
AUTH_RATE_LIMIT_MAX=20
